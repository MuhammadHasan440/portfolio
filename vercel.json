{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "echo 'Static site - no build required'",
  "outputDirectory": ".",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/send-email",
      "dest": "/server.js"
    },
    {
      "src": "/",
      "dest": "/index-2.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index-2.html"
    }
  ]
}